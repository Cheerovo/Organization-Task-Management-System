# PostgreSQL — Render 会自动提供 DATABASE_URL（Internal Database URL）
# 本地开发可设置: postgresql://localhost:5432/otms
DATABASE_URL=postgresql://localhost:5432/otms

# JWT 密钥（生产环境请修改）
JWT_SECRET=otms-secret-key-change-in-production

# 钉钉开发者后台 → 应用开发 → 凭证与基础信息（可选）
DINGTALK_APP_KEY=your_app_key
DINGTALK_APP_SECRET=your_app_secret
PORT=3456
